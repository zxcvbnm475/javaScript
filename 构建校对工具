在本实验中，你将构建一个校对工具，用于分析字串数组中的回文和重复短语。

回文是指正读和反读都相同的字串。例如，"racecar" 和 "level" 是回文，但 "hello" 不是。

短语是一段连续的单词序列。例如，在 ["the", "cat", "sat", "the", "cat"] 中，短语 "the cat"（由 2 个单词组成的序列）出现在位置 0 和 3。

目标： 完成以下用户故事并通过所有测试以完成本实验。

用户故事：

你应该定义一个名为 isPalindrome 的函数，它接受一个 word 字串作为参数。如果该字串正读和反读相同（不区分大小写），则应返回 true，否则返回 false。

你应该定义一个名为 findPalindromeBreaks 的函数，它接受一个 words 数组作为参数。它应返回一个包含非回文单词索引的数组。如果输入为空，则返回空数组。

你应该定义一个名为 findRepeatedPhrases 的函数，它接受一个 words 数组和一个 phraseLength 数字作为参数。它应返回一个数组，包含所有 phraseLength 个连续单词序列在数组中出现多次的起始索引——包括首次出现的索引。如果 phraseLength 大于或等于 words 的长度，则返回空数组。重叠的序列也应计入。

你应该定义一个名为 analyzeTexts 的函数，它接受一个 texts 数组和一个 phraseLength 数字作为参数。它应处理 texts 中的每个元素（每个元素都是一个单词数组），并返回一个包含 repeatedPhrases 和 palindromeBreaks 属性的对象数组。如果 texts 为空，则返回空数组。

/**
 * 判断单词是否为回文（不区分大小写）
 * @param {string} word
 * @returns {boolean}
 */
function isPalindrome(word) {
  const lower = word.toLowerCase();
  const reversed = lower.split('').reverse().join('');
  return lower === reversed;
}

/**
 * 获取所有非回文单词的索引数组
 * @param {string[]} words
 * @returns {number[]}
 */
function findPalindromeBreaks(words) {
  const breaks = [];
  for (let i = 0; i < words.length; i++) {
    if (!isPalindrome(words[i])) {
      breaks.push(i);
    }
  }
  return breaks;
}

/**
 * 查找所有重复短语的起始下标（包含首次出现位置）
 * @param {string[]} words 单词数组
 * @param {number} phraseLength 短语单词个数
 * @returns {number[]}
 */
function findRepeatedPhrases(words, phraseLength) {
  const len = words.length;
  const result = [];
  // 短语长度大于等于总单词数，直接返回空
  if (phraseLength >= len) return result;

  // key: 短语字符串, value: 出现过的起始索引列表
  const phraseMap = new Map();

  // 遍历所有可能的起始位置
  for (let start = 0; start <= len - phraseLength; start++) {
    // 截取连续phraseLength个单词拼接成唯一标识
    const phrase = words.slice(start, start + phraseLength).join(' ');
    if (!phraseMap.has(phrase)) {
      phraseMap.set(phrase, []);
    }
    phraseMap.get(phrase).push(start);
  }

  // 收集所有出现次数≥2的短语对应的全部下标
  for (const indexes of phraseMap.values()) {
    if (indexes.length >= 2) {
      result.push(...indexes);
    }
  }
  return result;
}

/**
 * 批量分析多段文本
 * @param {string[][]} texts 二维数组，每一项是一段单词数组
 * @param {number} phraseLength
 * @returns {Array<{repeatedPhrases: number[], palindromeBreaks: number[]}>}
 */
function analyzeTexts(texts, phraseLength) {
  const output = [];
  for (const wordArr of texts) {
    const palindromeBreaks = findPalindromeBreaks(wordArr);
    const repeatedPhrases = findRepeatedPhrases(wordArr, phraseLength);
    output.push({
      repeatedPhrases,
      palindromeBreaks
    });
  }
  return output;
}

// ==================== 测试示例 ====================
// 测试1：isPalindrome
console.log(isPalindrome("Racecar")); // true
console.log(isPalindrome("Hello"));    // false

// 测试2：findPalindromeBreaks
const words1 = ["level", "cat", "Madam", "book"];
console.log(findPalindromeBreaks(words1)); // [1, 3]

// 测试3：findRepeatedPhrases
const words2 = ["the", "cat", "sat", "the", "cat"];
console.log(findRepeatedPhrases(words2, 2)); // [0,3]

// 测试重叠短语
const words3 = ["a", "b", "a", "b", "a"];
console.log(findRepeatedPhrases(words3, 2)); // [0,2]

// 测试4：analyzeTexts
const texts = [
  ["racecar", "dog", "level"],
  ["hi", "mom", "hi", "mom"]
];
console.log(analyzeTexts(texts, 2));
/*
[
  { repeatedPhrases: [], palindromeBreaks: [1] },
  { repeatedPhrases: [0,2], palindromeBreaks: [0,2] }
]
*/
