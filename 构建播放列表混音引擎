/**
 * 1. 扁平化多维播放列表，新增 source 来源标记
 * @param {Array} playlists 二维播放列表数组
 * @returns {Array} 一维曲目数组，携带 source: [playlistIndex, trackIndex]
 */
function flattenPlaylists(playlists) {
  // 输入非数组直接返回空数组
  if (!Array.isArray(playlists)) return [];
  const flat = [];

  for (let listIdx = 0; listIdx < playlists.length; listIdx++) {
    const playlist = playlists[listIdx];
    if (!Array.isArray(playlist)) continue;

    for (let trackIdx = 0; trackIdx < playlist.length; trackIdx++) {
      const track = playlist[trackIdx];
      flat.push({
        ...track,
        source: [listIdx, trackIdx]
      });
    }
  }
  return flat;
}

/**
 * 2. 为每首曲目计算 score 分数
 * 公式：score = votes * 10 - Math.abs(bpm - 120)
 * @param {Array} tracks flattenPlaylists 输出的曲目数组
 * @returns {Array} 新增 score 属性的新曲目数组
 */
function scoreTracks(tracks) {
  return tracks.map(track => {
    const score = track.votes * 10 - Math.abs(track.bpm - 120);
    return {
      ...track,
      score
    };
  });
}

/**
 * 3. 根据 trackId 去重，仅保留第一次出现的曲目
 * @param {Array} scoredTracks scoreTracks 输出数组
 * @returns {Array} 无重复曲目数组
 */
function dedupeTracks(scoredTracks) {
  const seenIds = new Set();
  const unique = [];
  for (const track of scoredTracks) {
    if (!seenIds.has(track.trackId)) {
      seenIds.add(track.trackId);
      unique.push(track);
    }
  }
  return unique;
}

/**
 * 4. 限制同一艺术家最大出现次数，保留最早出现的曲目
 * @param {Array} uniqueTracks dedupe 后的曲目数组
 * @param {number} maxPerArtist 每位艺术家最大允许曲目数
 * @returns {Array} 过滤后不超配额的曲目数组
 */
function enforceArtistQuota(uniqueTracks, maxPerArtist) {
  const artistCounter = new Map();
  const filtered = [];

  for (const track of uniqueTracks) {
    const artist = track.artist;
    const currentCount = artistCounter.get(artist) || 0;
    if (currentCount < maxPerArtist) {
      filtered.push(track);
      artistCounter.set(artist, currentCount + 1);
    }
  }
  return filtered;
}

/**
 * 5. 构建播放调度数组，slot 从 1 开始自增
 * @param {Array} quotaTracks 配额过滤后的曲目数组
 * @returns {Array<{slot: number, trackId: any}>}
 */
function buildSchedule(quotaTracks) {
  return quotaTracks.map((track, index) => ({
    slot: index + 1,
    trackId: track.trackId
  }));
}

/**
 * 顶层混音入口函数，串联全流程
 * @param {Array} playlists 原始多维播放列表
 * @param {number} maxArtistLimit 单艺术家最大曲目上限
 * @returns {Array<{slot, trackId}>} 最终播放调度列表
 */
function remixPlaylist(playlists, maxArtistLimit) {
  const flat = flattenPlaylists(playlists);
  const scored = scoreTracks(flat);
  const deduped = dedupeTracks(scored);
  const quotaLimited = enforceArtistQuota(deduped, maxArtistLimit);
  const schedule = buildSchedule(quotaLimited);
  return schedule;
}

