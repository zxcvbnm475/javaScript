在本实验中，你将创建一个函数，将字串转换为标题大小写。标题大小写意味着每个单词的第一个字母大写，其余字母小写。

"Web Development Is Awesome" 是一个标题式分支的字串示例。

目标：完成以下用户故事并通过所有测试以完成实验。

用户故事：

你应该有一个 titleCase 函数，它接受一个字串作为参数。
titleCase 函数应返回一个字串，其中每个单词的首字母大写，其余字母小写。
titleCase("I like to code") 应该返回 "I Like To Code"。
titleCase("javaScript is fun") 应该返回 "Javascript Is Fun"。

解法一
function titleCase(str) {
  // 1. 把字符串按空格切成单词数组
  let words = str.split(' ');
  // 2. 遍历每个单词，统一格式化
  let newWords = words.map(word => {
    // 首字母大写 + 剩余字母全部小写
    return word[0].toUpperCase() + word.slice(1).toLowerCase();
  });
  // 3. 数组拼接回字符串，空格分隔
  return newWords.join(' ');
}
解法2
function titleCase(str) {
  let arr = str.split(' ');
  for(let i = 0; i < arr.length; i++){
    arr[i] = arr[i][0].toUpperCase() + arr[i].slice(1).toLowerCase();
  }
  return arr.join(' ');
}
